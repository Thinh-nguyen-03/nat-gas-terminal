# Data API keys
EIA_API_KEY=your_eia_key_here
FRED_API_KEY=your_fred_key_here
AIS_HUB_USERNAME=your_aishub_username  # optional: free account at aishub.net

# Paths (Docker overrides these)
DATA_BASE_DIR=/app/data

# Go API (used by Python collector to push SSE notify)
NOTIFY_API_URL=http://api:8080/internal/notify
INTERNAL_API_KEY=change-this-to-a-random-secret

# NextAuth (frontend auth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-random-secret

# Auth users (bcrypt hashes — generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',12))")
AUTH_USER_1_EMAIL=you@example.com
AUTH_USER_1_NAME=Your Name
AUTH_USER_1_HASH=$2b$12$...

# Frontend → Go API URL
API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# Go API port
API_PORT=8080
