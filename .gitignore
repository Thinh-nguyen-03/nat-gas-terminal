# Secrets — never commit
.env

# Python
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Go
api/vendor/
api/*.exe
api/api
api/*.txt
api/*.bat

# Node / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/

